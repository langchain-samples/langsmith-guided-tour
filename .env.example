# --- LangSmith (used across all modules: tracing, evals, deploy) ---
LANGSMITH_TRACING="true"
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY="<langsmith-api-key>"
LANGSMITH_PROJECT="langsmith-poc"

# --- Model providers (Anthropic is the default; uncomment another and edit utils/models.py to swap) ---
ANTHROPIC_API_KEY="<anthropic-api-key>"
# OPENAI_API_KEY="<openai-api-key>"

# Azure OpenAI (optional)
# AZURE_OPENAI_API_KEY="<azure-openai-api-key>"
# AZURE_OPENAI_ENDPOINT="<azure-openai-endpoint>"
# AZURE_OPENAI_API_VERSION=""

# AWS Bedrock (optional)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION_NAME=""
# AWS_MODEL_ARN=""

# --- Tools used by Modules 01-06 (web search for the agent) ---
TAVILY_API_KEY="<tavily-api-key>"
